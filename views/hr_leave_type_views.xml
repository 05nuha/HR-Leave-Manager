<odoo>

    <!-- action opens kanban first so the colored cards are the default view -->
    <record id="hr_leave_type_action" model="ir.actions.act_window">
        <field name="name">Leave Types</field>
        <field name="res_model">hr.leave.type</field>
        <field name="view_mode">kanban,list,form</field>
    </record>


    <!-- kanban view: each leave type is a color-coded card with key stats -->
    <record id="hr_leave_type_view_kanban" model="ir.ui.view">
        <field name="name">hr.leave.type.kanban</field>
        <field name="model">hr.leave.type</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="max_days"/>
                <field name="requires_approval"/>
                <field name="allocation_count"/>
                <field name="request_count"/>
                <field name="color"/>
                <field name="description"/>
                <templates>
                    <t t-name="card">
                        <!-- oe_kanban_color_N applies the standard Odoo color strip -->
                        <div t-attf-class="oe_kanban_color_#{record.color.raw_value} p-3">
                            <strong class="fs-5"><field name="name"/></strong>
                            <div class="text-muted mt-1">
                                <field name="description"/>
                            </div>
                            <hr/>
                            <div class="d-flex justify-content-between mt-2">
                                <span class="badge rounded-pill bg-info">
                                    <i class="fa fa-calendar"/> Max: <t t-esc="record.max_days.value"/> days
                                </span>
                                <!-- show approval badge depending on the requires_approval flag -->
                                <span t-if="record.requires_approval.raw_value" class="badge rounded-pill bg-warning text-dark">
                                    Approval Required
                                </span>
                                <span t-else="" class="badge rounded-pill bg-success">
                                    Auto-Approved
                                </span>
                            </div>
                            <div class="d-flex justify-content-between mt-2 text-muted">
                                <small><i class="fa fa-users"/> <t t-esc="record.allocation_count.value"/> Allocations</small>
                                <small><i class="fa fa-file-text"/> <t t-esc="record.request_count.value"/> Requests</small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- list view: added allocation/request counts as quick reference columns -->
    <record id="hr_leave_type_view_list" model="ir.ui.view">
        <field name="name">hr.leave.type.list</field>
        <field name="model">hr.leave.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="max_days"/>
                <field name="requires_approval" widget="boolean_toggle"/>
                <field name="allocation_count" string="Allocations"/>
                <field name="request_count" string="Requests"/>
            </list>
        </field>
    </record>

    <!-- form view: stat buttons at top link to filtered allocations and requests -->
    <record id="hr_leave_type_view_form" model="ir.ui.view">
        <field name="name">hr.leave.type.form</field>
        <field name="model">hr.leave.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!-- smart buttons — clicking these opens the related records filtered by this type -->
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_allocations" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="allocation_count" widget="statinfo" string="Allocations"/>
                        </button>
                        <button name="action_view_requests" type="object"
                                class="oe_stat_button" icon="fa-file-text">
                            <field name="request_count" widget="statinfo" string="Requests"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Leave Type Name..."/></h1>
                    </div>
                    <group>
                        <group string="Settings">
                            <field name="max_days"/>
                            <field name="requires_approval" widget="boolean_toggle"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group string="Description">
                            <field name="description" placeholder="Describe when this leave type applies..." nolabel="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
