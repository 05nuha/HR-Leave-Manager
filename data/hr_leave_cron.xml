<odoo noupdate="0">

    <!-- runs daily to auto-refuse draft/submitted requests whose dates have passed -->
    <record id="ir_cron_auto_refuse_expired_leaves" model="ir.cron">
        <field name="name">HR Leave: Auto-Refuse Expired Requests</field>
        <field name="model_id" ref="model_hr_leave_request"/>
        <field name="state">code</field>
        <field name="code">model.action_auto_refuse_expired()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
